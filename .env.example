# DiffDuel — эталон переменных окружения.
#
# Скопируй в .env и при необходимости поправь значения:
#   cp .env.example .env
# Файл .env НИКОГДА не коммитится (см. .gitignore). Секреты прода —
# только через GitHub Secrets → env на сервере, не сюда.
#
# Значения ниже рассчитаны на dev-стек из infra/compose/docker-compose.yml
# (порты проброшены на host, поэтому хосты — localhost).

# ───────────────────────── Окружение ─────────────────────────
# dev | test | prod — переключает поведение приложений (логи, debug и т.п.).
APP_ENV=dev

# ───────────────────────── PostgreSQL ─────────────────────────
# async-драйвер asyncpg; формат: postgresql+asyncpg://user:pass@host:port/db
DATABASE_URL=postgresql+asyncpg://diffduel:diffduel@localhost:5432/diffduel

# ───────────────────────── Redis ─────────────────────────
# В dev — без пароля; /0 — номер логической БД.
REDIS_URL=redis://localhost:6379/0

# ───────────────────────── Kafka / Redpanda ─────────────────────────
# host-листенер Redpanda (внутри docker-сети сервисы используют redpanda:9092).
KAFKA_BROKERS=localhost:19092

# ───────────────────────── MinIO / S3 ─────────────────────────
# S3-совместимый эндпоинт MinIO.
S3_ENDPOINT=http://localhost:9000
# Учётки доступа к MinIO (в dev совпадают с root-кредами из compose).
S3_ACCESS_KEY=diffduel
S3_SECRET_KEY=diffduel-dev-secret
# Публичный префикс для раздачи объектов (в проде — домен CDN).
S3_PUBLIC_BASE_URL=http://localhost:9000

# ───────────────────────── Auth / JWT ─────────────────────────
# !!! СГЕНЕРИРУЙ СВОЙ СЕКРЕТ: openssl rand -hex 64
# Требование: >= 64 случайных байт. В проде — только из секрет-хранилища.
JWT_SECRET=CHANGE_ME_сгенерируй_через_openssl_rand_hex_64
# TTL токенов в секундах: access 15 мин, refresh 30 дней.
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Токен для внутренних вызовов realtime → api (/internal/*).
# !!! СГЕНЕРИРУЙ СВОЙ: openssl rand -hex 32
INTERNAL_API_TOKEN=CHANGE_ME_сгенерируй_через_openssl_rand_hex_32

# Доверять заголовку X-Forwarded-For при определении IP клиента (rate limiting).
# false в dev (API доступен напрямую); true ТОЛЬКО за нашим Traefik в проде.
TRUST_PROXY=false

# ───────────────────────── Observability ─────────────────────────
# Пусто = Sentry выключен. В проде — DSN проекта из секретов.
SENTRY_DSN=

# ───────────────────────── CORS ─────────────────────────
# Источники, которым разрешён доступ к API: web SPA (5173) и admin (5174).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ───────────────────────── Observability (OTel) ─────────────────────────
# Endpoint OTLP-коллектора. Пусто = телеметрия не экспортируется (no-op).
# Для dev-стека observability (compose.observability.yml) — http://localhost:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=diffduel-api
