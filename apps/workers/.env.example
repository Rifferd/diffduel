# DiffDuel workers — эталон env (.env не коммитится). Имена — по conventions.md.

APP_ENV=dev

# Kafka / Redpanda — консьюмер duels.finished.
KAFKA_BROKERS=localhost:19092
KAFKA_GROUP_ID=image-gen
KAFKA_TOPIC=duels.finished

# S3 / MinIO — публичный бакет share-карточек.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=diffduel
S3_SECRET_KEY=diffduel-dev-secret
S3_REGION=us-east-1
S3_BUCKET_SHARE_CARDS=share-cards

# Core API internal-эндпоинт (запись share_card_key).
CORE_API_URL=http://localhost:8000
INTERNAL_API_TOKEN=dev-internal-token-change-me

# Устойчивость обработки.
PROCESS_MAX_ATTEMPTS=3
