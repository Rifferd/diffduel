{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": []
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Inter, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--arena",
      "--arena-2",
      "--arena-ink",
      "--arena-line",
      "--arena-soft",
      "--ava-1",
      "--ava-2",
      "--ava-3",
      "--ava-4",
      "--ava-5",
      "--ava-6",
      "--bg",
      "--code-comment",
      "--code-err-bg",
      "--code-keyword",
      "--code-string",
      "--focus-ring",
      "--font-body",
      "--font-display",
      "--font-mono",
      "--frame",
      "--ink",
      "--ink-soft",
      "--line",
      "--minus",
      "--minus-bg",
      "--minus-bright",
      "--plus",
      "--plus-bg",
      "--plus-bright",
      "--plus-hover",
      "--radius",
      "--radius-lg",
      "--radius-pill",
      "--row-alt",
      "--seg-bg",
      "--shadow",
      "--shadow-card",
      "--shadow-cta",
      "--share-draw-l",
      "--share-draw-r",
      "--share-minus",
      "--share-plus",
      "--skeleton-mid",
      "--space",
      "--space-1",
      "--space-12",
      "--space-16",
      "--space-2",
      "--space-3",
      "--space-4",
      "--space-6",
