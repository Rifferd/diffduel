{
  "title": "DiffDuel — RED + продуктовые метрики",
  "uid": "diffduel-main",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP rate (RED: Rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_duration_milliseconds_count[5m])) by (service_name)", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP errors (RED: Errors, 5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[5m])) by (service_name)", "legendFormat": "{{service_name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "answer_check_latency p95 (цель ≤150мс)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(answer_check_latency_milliseconds_bucket[5m])) by (le, mode))", "legendFormat": "p95 {{mode}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "duel_match_time_seconds p50 (цель ≤20с)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(duel_match_time_seconds_bucket[5m])) by (le))", "legendFormat": "p50" }
      ]
    },
    {
      "type": "stat",
      "title": "ws_connections (активные сокеты /duel)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(ws_connections)", "legendFormat": "WS" }
      ]
    }
  ]
}
