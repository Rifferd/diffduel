# DiffDuel — ПРОДАКШЕН-окружение. Скопировать в .env.prod на сервере и заполнить.
# .env.prod НИКОГДА не коммитится. Секреты генерировать на сервере, не на ноутбуке.
#
#   cp .env.prod.example .env.prod && nano .env.prod
#   openssl rand -hex 64   # для JWT_SECRET
#   openssl rand -hex 32   # для INTERNAL_API_TOKEN, паролей
#
# ВАЖНО: docker compose env_file НЕ вырезает инлайн-комментарии — поэтому здесь
# комментарии только на отдельных строках, а в значениях ничего лишнего.

# ───────── окружение и домен ─────────
APP_ENV=prod
DOMAIN=diffduel.com
# email для Let's Encrypt
ACME_EMAIL=admin@diffduel.com
# владелец образов в GHCR (нижним регистром)
GHCR_OWNER=rifferd
# деплой переопределяет на git sha
IMAGE_TAG=latest

# ───────── PostgreSQL ─────────
POSTGRES_USER=diffduel
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32
POSTGRES_DB=diffduel
DATABASE_URL=postgresql+asyncpg://diffduel:CHANGE_ME_openssl_rand_hex_32@postgres:5432/diffduel

# ───────── Redis ─────────
REDIS_URL=redis://redis:6379/0

# ───────── Kafka / Redpanda ─────────
KAFKA_BROKERS=redpanda:9092
KAFKA_GROUP_ID=image-gen
KAFKA_TOPIC=duels.finished

# ───────── MinIO / S3 ─────────
# внутренний адрес для api/workers
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=diffduel
S3_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
S3_REGION=us-east-1
S3_BUCKET_SHARE_CARDS=share-cards
# публичный CDN-префикс share-карточек (Traefik-роут cdn.DOMAIN → MinIO)
S3_PUBLIC_BASE_URL=https://cdn.diffduel.com

# ───────── Auth / JWT (одинаковый секрет в api и realtime!) ─────────
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
INTERNAL_API_TOKEN=CHANGE_ME_openssl_rand_hex_32

# ───────── сеть/прокси ─────────
# API за Traefik — доверяем X-Forwarded-For
TRUST_PROXY=true
CORS_ORIGINS=https://diffduel.com,https://www.diffduel.com,https://admin.diffduel.com

# ───────── realtime (TypeScript-сервис) ─────────
PORT=8100
# внутренний вызов realtime → api
CORE_API_URL=http://api:8000
DUEL_TASKS_COUNT=5
DUEL_TASK_SECONDS=30

# ───────── observability ─────────
# DSN проекта Sentry (пусто = выключено)
SENTRY_DSN=
